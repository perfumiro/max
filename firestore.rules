rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin helper ─────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'admin@ipordise.com';
    }

    // ── Reviews ─────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == request.resource.data.uid;
    }

    // ── User profiles ────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Orders ───────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Anyone (including guests) can create an order
      allow create: if true;
      // Owner can read their own order (matched by phone or email)
      allow read: if true;
      // Only admin can update (status changes)
      allow update, delete: if isAdmin();
    }

    // ── Order counter (for sequential order IDs) ─────────────────────────────
    match /order_counter/{year} {
      allow read, write: if true;
    }

    // ── User orders subcollection ─────────────────────────────────────────────
    match /users/{userId}/orders/{orderId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ── Analytics: any authenticated user (incl. anonymous) can write ────
    //               only admin can read
    match /analytics_sessions/{sid} {
      allow read:  if isAdmin();
      allow write: if request.auth != null;
    }

    match /analytics_daily/{day} {
      allow read:  if isAdmin();
      allow write: if request.auth != null;
    }

    match /analytics_products/{productId} {
      allow read:  if isAdmin();
      allow write: if request.auth != null;
    }

    match /analytics_live/{docId} {
      allow read:  if isAdmin();
      allow write: if request.auth != null;
    }

    // ── Admin config (force-logout timestamp) ────────────────────────────
    match /admin_config/{docId} {
      allow read, write: if isAdmin();
    }

  }
}
